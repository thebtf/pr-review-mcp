{
  "name": "pr-review-mcp",
  "version": "0.3.0",
  "description": "MCP server for PR review processing with GraphQL-based GitHub integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "pr-review-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    ".mcp.json",
    "commands",
    "README.md",
    "README.ru.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "claude-code-plugin",
    "coderabbit",
    "gemini",
    "copilot",
    "sourcery",
    "qodo",
    "greptile",
    "github",
    "pr-review",
    "code-review",
    "model-context-protocol",
    "graphql",
    "multi-agent",
    "orchestration"
  ],
  "author": "thebtf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thebtf/pr-review-mcp.git"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/plugin-retry": "^8.0.3",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
