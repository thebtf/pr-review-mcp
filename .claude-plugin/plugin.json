{
  "name": "pr-review-mcp",
  "version": "0.2.0",
  "description": "Orchestrate AI-driven PR reviews at scale. Unified MCP interface for CodeRabbit, Gemini, Copilot, Sourcery, Qodo, Codex, and Greptile with parallel multi-agent coordination.",
  "author": {
    "name": "thebtf",
    "url": "https://github.com/thebtf"
  },
  "homepage": "https://github.com/thebtf/pr-review-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/thebtf/pr-review-mcp.git"
  },
  "license": "MIT",
  "keywords": [
    "pr-review",
    "code-review",
    "coderabbit",
    "gemini",
    "copilot",
    "sourcery",
    "qodo",
    "greptile",
    "github",
    "mcp",
    "orchestration",
    "multi-agent"
  ],
  "mcpServers": {
    "pr": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
